.*~
.*.swp
.env
# sl-repl credentials hold a real password — never commit them. The
# checked-in template is sl-repl/testdata/credentials.example.toml.
credentials.toml
credentials.*.toml
# sl-conformance fixtures hold operator-specific grid ids (e.g. a pre-made
# group), so they are local-only like the credentials files.
fixtures.toml
fixtures.*.toml
# default log files the REPL binaries write into the working dir
sl-repl-tokio.log
sl-repl-bevy.log
# sl-conformance local run state (per-avatar aditi login cooldown stamps) and log
/.sl-conformance/
sl-conformance.log
tarpaulin-report.html
tarpaulin-report.json
/target
/book/book
bom.xml
bom.json
perf.data
perf.data.old
flamegraph.svg
# Python bytecode cache (roadmap/index.py is imported by ad-hoc tooling)
__pycache__/
*.pyc

# Runtime-generated viewer settings (persisted per user, not committed)
viewer-settings.json
viewer-settings.toml
